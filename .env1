# ===========================================
# CONFIGURAÇÕES DE EMAIL (OPCIONAIS)
# ===========================================

# Para envio de emails via Resend (ATUAL - Recomendado)
RESEND_API_KEY=re_seu_api_key_aqui

# Para envio de emails via SendGrid (alternativo)
SENDGRID_API_KEY=SG.seu_api_key_aqui

# Email remetente padrão
FROM_EMAIL=contato@contratandoplanos.com.br

# ===========================================
# CONFIGURAÇÕES DO NETLIFY EMAIL FUNCTIONS
# ===========================================
# ATENÇÃO: Estas variáveis são para Netlify Email Functions
# Se você estiver usando Supabase Edge Functions (atual), NÃO precisa dessas

# Diretório dos templates de email do Netlify
NETLIFY_EMAILS_DIRECTORY=netlify/emails

# Secret para autenticação do Netlify Email Functions
NETLIFY_EMAILS_SECRET=seu_secret_aleatorio_aqui

# ===========================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# ===========================================

# Ambiente de execução
NODE_ENV=development

# URL base da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# CONFIGURAÇÕES DO WHATSAPP MULTI-LOGIN
# ===========================================

# Usar integração real com WhatsApp Web (true/false)
WHATSAPP_REAL=true
WHATSAPP_HEADLESS=false

# Caminho para armazenar sessões do WhatsApp
WHATSAPP_SESSION_PATH=./sessions

# Configurações do Puppeteer
WHATSAPP_HEADLESS=false
WHATSAPP_PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-gpu,--disable-web-security

# Caminho para o executável do Chrome (macOS)
PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Timeout para QR Code (em segundos)
WHATSAPP_QR_TIMEOUT=300

# ===========================================
# CONFIGURAÇÕES DE SEGURANÇA
# ===========================================

# Secret para JWT tokens (gere uma string aleatória)
JWT_SECRET=sua_string_secreta_muito_longa_e_aleatoria

# Secret para NextAuth (se usar)
NEXTAUTH_SECRET=outra_string_secreta_para_nextauth

# URL para NextAuth
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# CONFIGURAÇÕES DE STORAGE/UPLOAD
# ===========================================

# Tamanho máximo de upload (em bytes)
MAX_FILE_SIZE=10485760

# Tipos de arquivo permitidos
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# ===========================================
# CONFIGURAÇÕES DE API EXTERNA (OPCIONAIS)
# ===========================================

# Para integração com WhatsApp Business API
WHATSAPP_API_TOKEN=seu_token_whatsapp

# Para integração com APIs de CEP
VIACEP_API_URL=https://viacep.com.br/ws

# ===========================================
# CONFIGURAÇÕES DE MONITORAMENTO (OPCIONAIS)
# ===========================================

# Para Sentry (monitoramento de erros)
SENTRY_DSN=https://seu_dsn_sentry

# Para Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# CONFIGURAÇÕES DE PRODUÇÃO
# ===========================================

# Domínio de produção
PRODUCTION_URL=https://contratandoplanos.com.br

# Configurações de CORS
ALLOWED_ORIGINS=http://localhost:3000,https://contratandoplanos.com.br
